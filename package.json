{
	"name": "@scalekit-inc/cli",
	"version": "0.3.3",
	"description": "Scalekit CLI",
	"type": "module",
	"bin": {
		"scalekit": "./bin/cli.js",
		"sk": "./bin/cli.js"
	},
	"files": [
		"bin",
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/scalekit-inc/cli"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "pnpm build && vitest run test/e2e",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"publint": "publint",
		"prepublishOnly": "npm run test && npm run build && npm run publint",
		"release": "np --no-tests"
	},
	"keywords": [
		"scalekit",
		"cli",
		"auth"
	],
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^1.4.0",
		"cfonts": "^3.3.1",
		"commander": "^14.0.3",
		"picocolors": "^1.1.1",
		"semver": "^7.8.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.7.0",
		"@types/semver": "^7.7.1",
		"execa": "^9.6.1",
		"np": "^11.2.0",
		"publint": "^0.3.20",
		"strip-ansi": "^7.2.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
