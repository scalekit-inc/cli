{
	"name": "@scalekit-inc/cli",
	"version": "0.1.0",
	"description": "Scalekit CLI",
	"type": "module",
	"bin": {
		"scalekit": "./bin/cli.js",
		"sk": "./bin/cli.js"
	},
	"files": [
		"bin",
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"publint": "publint",
		"prepublishOnly": "npm run build && npm run publint",
		"release": "np --any-branch --no-tests"
	},
	"keywords": [
		"scalekit",
		"cli",
		"auth"
	],
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^1.4.0",
		"cfonts": "^3.3.1",
		"commander": "^14.0.3",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.7.0",
		"np": "^11.2.0",
		"publint": "^0.3.20",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}
